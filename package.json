{
  "name": "leaf-map-window",
  "version": "1.0.0",
  "description": "Interaktivní webová aplikace pro vizualizaci prostorových dat s využitím knihovny Leaflet, jeho rozšířeních a 3D mapových technologií",
  "main": "dist/leaf-map-window.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "webpack && tsc --project tsconfig.build.json --emitDeclarationOnly --noEmit false",
    "demo": "webpack serve --env demo",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "leaflet": "^1.9.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LukasVlasak/leaf-map-window.git"
  },
  "keywords": [
    "leaflet",
    "leafletjs",
    "maps",
    "spatial-data",
    "gis",
    "javascript",
    "web-app"
  ],
  "author": "Lukas Vlasak",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/LukasVlasak/leaf-map-window/issues"
  },
  "homepage": "https://github.com/LukasVlasak/leaf-map-window#readme",
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/fabric": "^5.3.11",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet-draw": "^1.0.13",
    "@types/proj4": "^2.19.0",
    "@types/proj4leaflet": "^1.0.12",
    "css-loader": "^7.1.4",
