    "leaflet": "^1.9.4",
    "mini-css-extract-plugin": "^2.10.2",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "dompurify": "^3.4.2",
    "fabric": "^5.5.2",
    "leaflet-draw": "^1.0.4",
